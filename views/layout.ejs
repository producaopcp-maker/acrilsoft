<!doctype html>
<html lang="pt-br" data-theme="dark" data-accent="blue">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title><%= title || "Acrilsoft" %></title>
  <link rel="stylesheet" href="/styles.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  <script defer src="/ui.js"></script>
  <%- (typeof extraHead !== "undefined" ? extraHead : "") %>

<style>
.page-header {
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  margin-bottom:24px;
}

.page-header-left h1 {
  margin:0;
  font-size:22px;
  font-weight:600;
}

.page-header-left p {
  margin:6px 0 0 0;
  color:#6b7280;
  font-size:14px;
}

.page-header-actions {
  display:flex;
  gap:12px;
  align-items:center;
}

.page-header-actions .btn {
  min-width:140px;
}
</style>

</head>
<body>
  <div class="app-shell">
    <aside class="sidebar">
      <div class="sb-brand">
        <a class="brand-link" href="/dashboard" aria-label="Ir para o Dashboard">
          <div class="brand-wrap">
            <img class="brand-full" src="/assets/acrilsoft-brand.png" alt="Acrilsoft">
          </div>
        </a>
      </div>

      <nav class="sb-nav">
        <% const can = (m) => (typeof canModule === 'function' ? canModule(m) : true); %>
        <% const ico = (name) => `<i data-lucide="${name}" class="sb-ico"></i>`; %>

        <% if (can('dashboard')) { %>
          <a class="sb-link" href="/dashboard"><%- ico('layout-dashboard') %> <span class="sb-text">Dashboard</span></a>
          <a class="sb-link" href="/dashboard/multicanal" data-title="Painel Multicanal"><%- ico('bar-chart-3') %> <span class="sb-text">Multicanal</span></a>
        <% } %>

        <% if (can('pedidos') || can('bling') || can('novo_pedido')) { %>
          <div class="sb-group">
            <div class="sb-group-title">Comercial</div>

            <% if (can('pedidos')) { %>
              <a class="sb-link" href="/orcamentos"><%- ico('file-text') %> <span class="sb-text">Orçamentos</span></a>
              <a class="sb-link" href="/pedidos"><%- ico('shopping-cart') %> <span class="sb-text">Pedidos</span></a>
            <% } %>

            <% if (can('novo_pedido')) { %>
              <a class="sb-link" href="/pedidos/novo"><%- ico('plus-square') %> <span class="sb-text">Novo Pedido</span></a>
            <% } %>

            <% if (can('pedidos')) { %>
              <a class="sb-link" href="/pedidos/kanban"><%- ico('kanban') %> <span class="sb-text">Controle de Pedidos</span></a>
            <% } %>
</div>
        <% } %>

        <% if (can('ops') || can('servicos')) { %>
          <div class="sb-group">
            <div class="sb-group-title">Produção</div>
            <% if (can('ops')) { %>
              <a class="sb-link" href="/ops"><%- ico('factory') %> <span class="sb-text">Ordens de Produção</span></a>
              <a class="sb-link" href="/ops/arquivadas"><%- ico('archive') %> <span class="sb-text">Arquivo OPs</span></a>
            <% } %>
            <% if (can('servicos')) { %>
              <a class="sb-link" href="/servicos"><%- ico('wrench') %> <span class="sb-text">Serviços</span></a>
            <% } %>
          </div>
        <% } %>

        <% if (can('estoque') || can('insumos')) { %>
          <div class="sb-group">
            <div class="sb-group-title">Estoque</div>
            <% if (can('estoque')) { %>
              <a class="sb-link" href="/estoque"><%- ico('boxes') %> <span class="sb-text">Estoque</span></a>
                            <a class="sb-link" href="/cadastro-produtos"><%- ico('package') %> <span class="sb-text">Produtos</span></a>
              <a class="sb-link" href="/cadastro-produtos/novo"><%- ico('square-plus') %> <span class="sb-text">Novo Produto</span></a>
<a class="sb-link" href="/produtos/novo"><%- ico('square-plus') %> <span class="sb-text">Nova Chapa</span></a>
              <a class="sb-link" href="/historico"><%- ico('history') %> <span class="sb-text">Histórico</span></a>
            <% } %>
            <% if (can('insumos')) { %>
              <a class="sb-link" href="/insumos"><%- ico('layers') %> <span class="sb-text">Insumos</span></a>
            <% } %>
          </div>
        <% } %>

        <% if (can('brindes')) { %>
          <div class="sb-group">
            <div class="sb-group-title">Brindes</div>
            <a class="sb-link" href="/brindes/orcamentos"><%- ico('file-text') %> <span class="sb-text">Orçamentos</span></a>
            <a class="sb-link" href="/brindes/catalogo"><%- ico('list') %> <span class="sb-text">Catálogo</span></a>
            <a class="sb-link" href="/brindes/personalizacoes"><%- ico('sparkles') %> <span class="sb-text">Personalizações</span></a>
            <a class="sb-link" href="/brindes/estoque"><%- ico('gift') %> <span class="sb-text">Estoque</span></a>
            <a class="sb-link" href="/brindes/novo"><%- ico('plus-square') %> <span class="sb-text">Novo Brinde</span></a>
            <a class="sb-link" href="/brindes/historico"><%- ico('clipboard-list') %> <span class="sb-text">Histórico</span></a>
          </div>
        <% } %>

        <% if (can('fornecedores') || can('clientes')) { %>
          <div class="sb-group">
            <div class="sb-group-title">Cadastros</div>
            <% if (can('fornecedores')) { %>
              <a class="sb-link" href="/fornecedores"><%- ico('truck') %> <span class="sb-text">Fornecedores</span></a>
            <% } %>
            <% if (can('clientes')) { %>
              <a class="sb-link" href="/clientes"><%- ico('users') %> <span class="sb-text">Clientes</span></a>
            <% } %>

          </div>
        <% } %>

        
        <% if (can('logistica')) { %>
          <div class="sb-group">
            <div class="sb-group-title">Logística</div>
            <a class="sb-link" href="/logistica/expedicao"><%- ico('truck') %> <span class="sb-text">Expedição</span></a>
          </div>
        <% } %>

<% if (can('financeiro') || can('relatorios') || can('fiscal')) { %>
          <div class="sb-group">
            <div class="sb-group-title">Financeiro</div>
            <% if (can('financeiro')) { %>
              <a class="sb-link" href="/financeiro"><%- ico('wallet') %> <span class="sb-text">Visão Geral</span></a>
              <a class="sb-link" href="/financeiro/receber"><%- ico('arrow-down-left') %> <span class="sb-text">Contas a Receber</span></a>
              <a class="sb-link" href="/financeiro/pagar"><%- ico('arrow-up-right') %> <span class="sb-text">Contas a Pagar</span></a>
              <a class="sb-link" href="/financeiro/fluxo"><%- ico('line-chart') %> <span class="sb-text">Fluxo de Caixa</span></a>
              <a class="sb-link" href="/financeiro/contas"><%- ico('landmark') %> <span class="sb-text">Contas (Caixa/Banco)</span></a>
              <a class="sb-link" href="/financeiro/plano-contas"><%- ico('list-tree') %> <span class="sb-text">Plano de Contas</span></a>
            <% } %>
            <% if (can('fiscal')) { %>
              <a class="sb-link" href="/financeiro/fiscal"><%- ico('file-text') %> <span class="sb-text">Fiscal (NF-e)</span></a>
            <% } %>
            <% if (can('relatorios')) { %>
              <a class="sb-link" href="/relatorio/mensal"><%- ico('bar-chart-3') %> <span class="sb-text">Relatório Mensal</span></a>
            <% } %>
          </div>
        <% } %>

        <!-- Menu antigo de configurações removido: agora tudo fica dentro de /configuracoes -->
      
        <% if (can('usuarios') || can('integracoes') || can('bling') || can('backup') || can('branding')) { %>
          <div class="sb-group">
            <div class="sb-group-title">Sistema</div>
            <a class="sb-link <%= ((typeof activeMenu!=='undefined' && activeMenu==='configuracoes')?'active':'') %>" href="/configuracoes"><%- ico('settings') %> <span class="sb-text">Configurações</span></a>
          </div>
        <% } %>
</nav>

      <div class="sb-footer">
        <div class="sb-tip">
          Exportar: <b>Excel</b><br/>
          Backup: <b>20:00</b>
        </div>
      </div>
    </aside>

    <main class="main">
      <header class="topbar">
        <div class="topbar-left">
          <button class="btn btn-ghost sb-toggle" type="button" aria-label="Abrir menu"><i data-lucide="menu"></i></button>
          <div class="crumb"><%= title || "Acrilsoft" %></div>
          <div class="muted db-status-line">
            <span id="dbModeText"><%= (typeof dbMode !== 'undefined' && dbMode==='online') ? 'Banco ONLINE' : 'Banco LOCAL' %></span>
            <span class="db-pill db-unknown" id="dbPill" title="Status do banco">• verificando…</span>
          </div>
        </div>

        <div class="topbar-actions">

          <button class="btn btn-outline sb-collapse" type="button" title="Recolher barra lateral">
            <span class="btn-ico"><i data-lucide="panel-left"></i></span><span class="hide-sm">Sidebar</span>
          </button>

          
          <div class="user-pill">
            <div class="user-avatar">👤</div>
            <div class="user-name"><%= (user && user.nome) ? user.nome : (typeof userName !== "undefined" ? userName : "Operator") %></div>
          </div>
          <% if (user) { %>
            <a class="btn btn-outline" href="/logout">Sair</a>
          <% } %>
          <% if (can('relatorios')) { %>
          <% } %>

        </div>
      </header>

      <section class="content">
        <%- include(view) %>
      </section>

      <footer class="footer">
        <small>Banco salvo no AppData • Uploads e anexos também</small>
      </footer>
    </main>
  </div>


  <!-- Modal padrão -->
  <div class="modal" id="appModal" aria-hidden="true">
    <div class="modal-backdrop" data-modal-close></div>
    <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="appModalTitle">
      <div class="modal-head">
        <div class="modal-title" id="appModalTitle">Modal</div>
        <button class="btn btn-ghost" type="button" data-modal-close aria-label="Fechar"><i data-lucide="x"></i></button>
      </div>
      <div class="modal-body" id="appModalBody"></div>
      <div class="modal-foot" id="appModalFoot">
        <button class="btn btn-outline" type="button" data-modal-close>Fechar</button>
      </div>
    </div>
  </div>

<% if (typeof query !== 'undefined' && query && query.ok) { %>
  <div class="toast toast-success" id="toastOk">
    <strong>OK</strong>
    <span><%= query.ok %></span>
    <button onclick="this.parentElement.remove()">✖</button>
  </div>
<% } %>

<% if (typeof query !== 'undefined' && query && query.erro) { %>
  <div class="toast toast-error" id="toast">
    <strong>Erro</strong>
    <span><%= query.erro %></span>
    <button onclick="this.parentElement.remove()">✖</button>
  </div>
<% } %>
<script>
  // Sidebar active link (único)
  (function(){
    try {
      var path = window.location.pathname || "/";
      var links = document.querySelectorAll(".sb-link");
      var best = null;
      links.forEach(function(a){
        var href = a.getAttribute("href") || "";
        if(!href || href === "#") return;
        if(path === href) best = a;
        else if(path.startsWith(href) && href.length > 1){
          if(!best || href.length > (best.getAttribute("href")||"").length) best = a;
        }
      });
      if(best) best.classList.add("active");
    } catch(e){}
  })();
</script>

<script>
  // Lucide icons
  try{ lucide.createIcons(); }catch(e){}
</script>

<script>
  // Mobile sidebar toggle
  (function(){
    var btn = document.querySelector('.sb-toggle');
    if(!btn) return;
    btn.addEventListener('click', function(){
      document.body.classList.toggle('sidebar-open');
    });
    document.addEventListener('click', function(e){
      if(!document.body.classList.contains('sidebar-open')) return;
      var sidebar = document.querySelector('.sidebar');
      if(!sidebar) return;
      if(sidebar.contains(e.target) || btn.contains(e.target)) return;
      document.body.classList.remove('sidebar-open');
    });
  })();
</script>


<script>
(function(){
  const KEY = "acrilsoft_theme";
  const root = document.documentElement;
  function apply(t){
    root.setAttribute("data-theme", t);
    try{ localStorage.setItem(KEY, t); }catch(e){}
    if(btn){
      btn.innerHTML = (t === 'dark')
        ? '<span class="btn-ico"><i data-lucide="sun"></i></span><span class="hide-sm">Tema</span>'
        : '<span class="btn-ico"><i data-lucide="moon"></i></span><span class="hide-sm">Tema</span>';
      try{ lucide.createIcons(); }catch(e){}
    }
  }
  function current(){ return root.getAttribute("data-theme") || "light"; }
  function toggle(){ apply(current()==="dark" ? "light" : "dark"); }

  let saved=null;
  try{ saved = localStorage.getItem(KEY); }catch(e){}
  const preferred = saved || ((window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) ? "dark" : "light");
  apply(preferred);

  if(btn){ btn.addEventListener("click", toggle); }
})();
</script>

<script>
// Indicador de status do banco (ONLINE/OFFLINE) + aviso amigável
(function(){
  var pill = document.getElementById('dbPill');
  var modeText = document.getElementById('dbModeText');
  if(!pill) return;

  function setPill(cls, text, title){
    pill.classList.remove('db-online','db-offline','db-unknown');
    pill.classList.add(cls);
    pill.textContent = text;
    if(title) pill.setAttribute('title', title);
  }

  function showToast(kind, title, msg){
    try{
      var old = document.getElementById('dbToast');
      if(old) old.remove();
      var div = document.createElement('div');
      div.id = 'dbToast';
      div.className = 'toast ' + (kind === 'success' ? 'toast-success' : 'toast-error');
      div.innerHTML = '<strong>'+title+'</strong><span>'+msg+'</span><button aria-label="Fechar">✖</button>';
      div.querySelector('button').onclick = function(){ div.remove(); };
      document.body.appendChild(div);
      // some sozinho
      setTimeout(function(){ try{ div.remove(); }catch(e){} }, 6000);
    }catch(e){}
  }

  var lastOk = null;
  async function check(){
    try{
      var r = await fetch('/api/db-status', { cache: 'no-store' });
      var st = await r.json();
      if(st && st.mode){
        if(modeText) modeText.textContent = (st.mode === 'online') ? 'Banco ONLINE' : 'Banco LOCAL';
      }

      if(st && st.ok){
        setPill('db-online', '• ONLINE', 'Banco conectado');
        if(lastOk === false){
          showToast('success','Banco ONLINE','Conexão restabelecida.');
        }
        lastOk = true;
      } else {
        setPill('db-offline', '• OFFLINE', (st && st.error) ? st.error : 'Sem conexão');
        if(lastOk === true){
          showToast('error','Banco OFFLINE','Sem conexão com o banco. Verifique a internet / token.');
        }
        lastOk = false;
      }
    } catch(e){
      setPill('db-offline', '• OFFLINE', 'Sem conexão');
      if(lastOk === true){
        showToast('error','Banco OFFLINE','Sem conexão com o banco.');
      }
      lastOk = false;
    }
  }

  // Primeira checagem rápida + pooling
  setPill('db-unknown','• verificando…','Checando conexão');
  check();
  setInterval(check, 8000);
})();
</script>

<%- (typeof extraScripts !== "undefined" ? extraScripts : "") %>

  <!-- Command Palette -->
  <div class="cmdk" id="cmdPalette" aria-hidden="true">
    <div class="cmdk-backdrop" data-cmdk-close></div>
    <div class="cmdk-panel" role="dialog" aria-modal="true" aria-label="Command Palette">
      <div class="cmdk-head">
        <i data-lucide="search"></i>
        <input id="cmdkInput" type="text" placeholder="Buscar telas e ações… (Ctrl+K)" autocomplete="off" />
        <kbd class="cmdk-kbd">Esc</kbd>
      </div>
      <div class="cmdk-hint muted">Digite para filtrar. Enter para abrir.</div>
      <div class="cmdk-list" id="cmdkList" role="listbox"></div>
    </div>
  </div>

</body>

</html>
