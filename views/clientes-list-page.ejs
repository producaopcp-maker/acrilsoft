<%
  const rows = Array.isArray(clientes) ? clientes : [];
  const f = filtros || {};
  function val(x){ return (x===null || x===undefined) ? '' : String(x); }
%>

<div class="card">
  <div class="card-head">
    <div>
      <div class="h1">Clientes</div>
      <div class="muted">Cadastro completo (PF/PJ) com endereços. Pedido pode ser avulso e vincular depois.</div>
    </div>
    <div class="card-actions">
      <a class="btn btn-primary" href="/clientes/novo">+ Novo Cliente</a>
    </div>
  </div>

  <form class="filters" method="get" action="/clientes" style="margin-top:10px;">
    <div class="row" style="display:flex; gap:10px; flex-wrap:wrap;">
      <div style="flex:1; min-width:220px;">
        <label class="lbl">Busca</label>
        <input class="inp" name="q" placeholder="nome, razão, CPF/CNPJ, telefone..." value="<%= val(f.q) %>">
      </div>
      <div style="min-width:160px;">
        <label class="lbl">Tipo</label>
        <select class="inp" name="tipo">
          <option value="">Todos</option>
          <option value="PF" <%= (val(f.tipo).toUpperCase()==='PF'?'selected':'') %>>PF</option>
          <option value="PJ" <%= (val(f.tipo).toUpperCase()==='PJ'?'selected':'') %>>PJ</option>
        </select>
      </div>
      <div style="align-self:end;">
        <button class="btn" type="submit">Filtrar</button>
        <a class="btn btn-ghost" href="/clientes">Limpar</a>
      </div>
    </div>
  </form>

  <div class="table-wrap" style="margin-top:12px;">
    <table class="table">
      <thead>
        <tr>
          <th style="width:90px;">#</th>
          <th>Cliente</th>
          <th style="width:140px;">Tipo</th>
          <th style="width:220px;">Documento</th>
          <th style="width:220px;">Contato</th>
          <th style="width:200px;">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (rows.length === 0) { %>
          <tr><td colspan="6" class="muted">Nenhum cliente encontrado.</td></tr>
        <% } %>

        <% rows.forEach(c => { %>
          <tr>
            <td><%= c.id %></td>
            <td>
              <div style="display:flex; flex-direction:column;">
                <b><%= c.nome_exibicao %></b>
                <% if (c.fantasia) { %><span class="muted"><%= c.fantasia %></span><% } %>
              </div>
            </td>
            <td><%= (c.tipo || '').toUpperCase() || '-' %></td>
            <td><%= c.cpf_cnpj || c.cnpjcpf || '-' %></td>
            <td><%= c.telefone || c.whatsapp || c.contato || '-' %></td>
            <td>
              <a class="btn btn-small" href="/clientes/<%= c.id %>">Abrir</a>
              <a class="btn btn-small btn-outline" href="/clientes/<%= c.id %>/editar">Editar</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
