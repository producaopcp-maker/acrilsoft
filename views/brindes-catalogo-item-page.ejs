<div class="card">
  <div class="card-head">
    <div>
      <div class="h1"><%= item?.nome || 'SKU' %></div>
      <div class="muted"><%= (item?.fornecedor_nome || '-') %> • <%= item?.codigo_fornecedor || '' %></div>
    </div>
    <div class="row gap">
      <a class="btn btn-ghost" href="/brindes/catalogo">Voltar</a>
    </div>
  </div>

  <div class="grid grid-2">
    <div class="card">
      <div class="h2">Dados</div>
      <div class="muted">Categoria: <b><%= item?.categoria || '-' %></b></div>
      <div class="muted">Unidade: <b><%= item?.unidade || 'UN' %></b></div>
      <div class="muted">Ativo: <b><%= item?.ativo ? 'Sim' : 'Não' %></b></div>
      <% if (item?.descricao) { %>
        <div style="margin-top:10px"><pre style="white-space:pre-wrap"><%= item.descricao %></pre></div>
      <% } %>
    </div>

    <div class="card">
      <div class="h2">Faixas de custo (unitário)</div>

      <form class="form" method="post" action="/brindes/catalogo/<%= item.id %>/precos">
        <div class="grid grid-4">
          <label class="field">
            <span>Qtd. mín</span>
            <input class="input" name="qtd_min" type="number" value="1" min="1" required>
          </label>
          <label class="field">
            <span>Qtd. máx (opcional)</span>
            <input class="input" name="qtd_max" type="number" min="1">
          </label>
          <label class="field">
            <span>Custo unit</span>
            <input class="input" name="custo_unitario" type="number" step="0.01" min="0" required>
          </label>
          <label class="field">
            <span>&nbsp;</span>
            <button class="btn" type="submit">Adicionar</button>
          </label>
        </div>
      </form>

      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Faixa</th>
              <th class="right">Custo unit</th>
              <th class="right">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% if (!precos || precos.length === 0) { %>
              <tr><td colspan="3" class="muted">Sem faixas cadastradas.</td></tr>
            <% } %>
            <% (precos || []).forEach((p) => { %>
              <tr>
                <td><%= p.qtd_min %> - <%= (p.qtd_max == null ? '∞' : p.qtd_max) %></td>
                <td class="right">R$ <%= Number(p.custo_unitario||0).toFixed(2) %></td>
                <td class="right">
                  <form method="post" action="/brindes/catalogo/<%= item.id %>/precos/<%= p.id %>/remover" style="display:inline">
                    <button class="btn btn-ghost" type="submit" onclick="return confirm('Remover faixa?')">Remover</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="muted" style="margin-top:10px">
        Dica: se tiver apenas um custo "a partir de", cadastre como <b>Qtd mín = 1</b> e deixe Qtd máx em branco.
      </div>
    </div>
  </div>
</div>
