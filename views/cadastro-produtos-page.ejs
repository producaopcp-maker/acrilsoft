<%
  const arr = Array.isArray(produtos) ? produtos : [];
  function val(x){ return (x===null||x===undefined)?'':String(x); }
%>

<div class="card">
  <div class="card-head">
    <div>
      <div class="h1">Produtos (Catálogo de Venda)</div>
      <div class="muted">Cadastre itens vendidos, com preço, fiscal e ficha técnica (consumo de chapa em m²).</div>
    </div>
    <div class="card-actions">
      <a class="btn" href="/cadastro-produtos/novo">Novo Produto</a>
    </div>
  </div>

  <form method="get" action="/cadastro-produtos" class="row" style="gap:10px; align-items:end; margin-top:8px;">
    <div style="flex:1;">
      <label class="lbl">Buscar</label>
      <input class="inp" name="q" value="<%= val(q) %>" placeholder="Nome / SKU / NCM">
    </div>
    <div style="width:170px;">
      <label class="lbl">Tipo</label>
      <select class="inp" name="tipo">
        <option value="">Todos</option>
        <option value="PRODUTO" <%= (tipo==='PRODUTO'?'selected':'') %>>Produto</option>
        <option value="SERVICO" <%= (tipo==='SERVICO'?'selected':'') %>>Serviço</option>
        <option value="MATERIA_PRIMA" <%= (tipo==='MATERIA_PRIMA'?'selected':'') %>>Matéria-prima</option>
      </select>
    </div>
    <button class="btn" type="submit">Filtrar</button>
    <a class="btn btn-ghost" href="/cadastro-produtos">Limpar</a>
  </form>

  <div class="table-wrap" style="margin-top:12px;">
    <table class="table">
      <thead>
        <tr>
          <th>Nome</th>
          <th style="width:120px;">SKU</th>
          <th style="width:90px;">Un</th>
          <th style="width:140px;">Preço</th>
          <th style="width:140px;">Custo</th>
          <th style="width:120px;">Tipo</th>
          <th style="width:90px;">Ativo</th>
          <th style="width:240px;"></th>
        </tr>
      </thead>
      <tbody>
        <% if (!arr.length) { %>
          <tr><td colspan="8" class="muted">Nenhum produto encontrado.</td></tr>
        <% } %>
        <% arr.forEach(p => { %>
          <tr>
            <td>
              <div style="font-weight:700;"><%= p.nome %></div>
              <div class="muted" style="font-size:12px;">
                <% if (p.ncm) { %>NCM: <%= p.ncm %> <% } %>
                <% if (p.cfop) { %> | CFOP: <%= p.cfop %> <% } %>
              </div>
            </td>
            <td><%= p.sku || '' %></td>
            <td><%= p.unidade || 'UN' %></td>
            <td><%= fmtBR(p.preco_venda || 0) %></td>
            <td><%= fmtBR(p.custo_unit || 0) %></td>
            <td><%= p.tipo || 'PRODUTO' %></td>
            <td><%= (p.ativo ? 'Sim' : 'Não') %></td>
            <td style="text-align:right;">
              <a class="btn btn-ghost" href="/cadastro-produtos/<%= p.id %>/bom">Ficha técnica</a>
              <a class="btn btn-ghost" href="/cadastro-produtos/<%= p.id %>">Editar</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
