<%
  const contas = Array.isArray(contasList) ? contasList : [];
%>
<div class="card">
  <div class="card-head">
    <div>
      <div class="h1">Contas (Caixa/Banco)</div>
      <div class="muted">Crie suas contas para controlar saldo e extrato.</div>
    </div>
    <div class="card-actions">
      <a class="btn btn-secondary" href="/financeiro">Voltar</a>
    </div>
  </div>

  <form method="post" action="/financeiro/contas" style="margin-top:12px; display:flex; gap:10px; flex-wrap:wrap;">
    <div style="min-width:260px;">
      <label class="lbl">Nome</label>
      <input class="inp" name="nome" required placeholder="Ex: Caixa, Banco, Mercado Pago">
    </div>
    <div style="min-width:200px;">
      <label class="lbl">Tipo</label>
      <select class="inp" name="tipo">
        <option value="BANCO">BANCO</option>
        <option value="CAIXA">CAIXA</option>
        <option value="CARTEIRA">CARTEIRA</option>
      </select>
    </div>
    <div style="align-self:end;">
      <button class="btn btn-primary" type="submit">+ Criar</button>
    </div>
  </form>

  <div class="table-wrap" style="margin-top:12px;">
    <table class="table">
      <thead>
        <tr>
          <th style="width:90px;">#</th>
          <th>Nome</th>
          <th>Tipo</th>
          <th style="width:120px;">Ativo</th>
        </tr>
      </thead>
      <tbody>
        <% if (!contas.length) { %>
          <tr><td colspan="4" class="muted">Nenhuma conta cadastrada.</td></tr>
        <% } %>
        <% contas.forEach(c => { %>
          <tr>
            <td><%= c.id %></td>
            <td><b><%= c.nome %></b></td>
            <td><%= c.tipo %></td>
            <td><%= (c.ativo ? 'Sim' : 'Não') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
