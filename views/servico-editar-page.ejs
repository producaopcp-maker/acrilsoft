<div class="card">
  <div class="h2">Editar serviço</div>

  <form method="post" action="/servicos/<%= servico.id %>" class="form">
    <div class="grid" style="grid-template-columns: 1fr 1fr; gap:12px;">
      <div>
        <div class="label">Nome *</div>
        <input class="input" name="nome" required value="<%= servico.nome %>" />
      </div>

      <div>
        <div class="label">Categoria</div>
        <input class="input" name="categoria" value="<%= servico.categoria || '' %>" />
      </div>

      <div>
        <div class="label">Unidade</div>
        <input class="input" name="unidade" value="<%= servico.unidade || '' %>" />
      </div>

      <div>
        <div class="label">Preço unitário</div>
        <input class="input" name="preco_unit" type="number" step="0.01" min="0" value="<%= Number(servico.preco_unit||0) %>" />
      </div>
    </div>

    <label style="display:flex; gap:8px; align-items:center; margin-top:12px;">
      <input type="checkbox" name="ativo" <%= Number(servico.ativo||0) ? "checked" : "" %> />
      <span>Ativo</span>
    </label>

    <div class="actions" style="margin-top:14px;">
      <button class="btn">Salvar</button>
      <a class="btn btn-ghost" href="/servicos">Voltar</a>
    </div>
  </form>
</div>
