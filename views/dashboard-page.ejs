<div class="page-head">
  <div>
    <div class="h1">Dashboard</div>
    <div class="muted">Visão geral do sistema • Período: desde <b><%= desde %></b></div>
  </div>

  <form class="row" method="get" action="/dashboard" style="gap:10px; align-items:flex-end;">
    <div>
      <div class="label">Período (dias)</div>
      <input class="input" name="dias" type="number" min="1" max="365" value="<%= String((typeof dias !== 'undefined' ? dias : 30)) %>" style="width:110px;" />
    </div>
    <button class="btn" type="submit">Aplicar</button>
  </form>
</div>


<div class="kpis">
  <div class="kpi kpi-warn">
    <div class="kpi-label">OPs atrasadas</div>
    <div class="kpi-value"><%= (kpis && kpis.ops_atrasadas) || 0 %></div>
    <div class="kpi-sub">Priorize as entregas vencidas</div>
  </div>

  <div class="kpi">
    <div class="kpi-label">OPs em andamento</div>
    <div class="kpi-value"><%= (kpis && kpis.ops_andamento) || 0 %></div>
    <div class="kpi-sub">Em produção / separação</div>
  </div>

  <div class="kpi">
    <div class="kpi-label">Vencendo em 7 dias</div>
    <div class="kpi-value"><%= (kpis && kpis.ops_vencendo_7d) || 0 %></div>
    <div class="kpi-sub">Planeje o fluxo desta semana</div>
  </div>

  <div class="kpi kpi-warn">
    <div class="kpi-label">Produtos abaixo do mínimo</div>
    <div class="kpi-value"><%= (kpis && kpis.produtos_abaixo_minimo) || 0 %></div>
    <div class="kpi-sub">Atenção no estoque de chapas</div>
  </div>

  <div class="kpi kpi-warn">
    <div class="kpi-label">Insumos abaixo do mínimo</div>
    <div class="kpi-value"><%= (kpis && kpis.insumos_abaixo_minimo) || 0 %></div>
    <div class="kpi-sub">Colas, fitas, limpeza, etc.</div>
  </div>
</div>

<div class="card" style="margin-top:14px;">
  <div class="card-head">
    <div>
      <div class="h2">Calendário de saídas (Semana)</div>
      <div class="muted">Mostra as OPs com data de entrega (inclui FINALIZADAS)</div>
    </div>
  </div>
  <div style="padding:12px;">
    <div id="opsCalendar"></div>
  </div>
</div>

<div class="grid" style="grid-template-columns: 1fr 1fr; gap:14px; align-items:start;">
  <div class="card">
    <div class="card-head">
      <div>
        <div class="h2">Estoque de chapas</div>
        <div class="muted">Itens abaixo do estoque mínimo</div>
      </div>
      <div class="actions">
        <a class="btn btn-ghost" href="/estoque">Ver estoque</a>
      </div>
    </div>

    <div>
      <div class="h3" style="margin:0 0 6px; display:flex; align-items:center; gap:8px;">
        <span class="mini-ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4a2 2 0 0 0 1-1.73Z"/>
            <path d="M3.3 7l8.7 5 8.7-5"/>
            <path d="M12 22V12"/>
          </svg>
        </span>
        Chapas
      </div>
        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th>Chapa</th>
                <th>Atual</th>
                <th>Mín.</th>
              </tr>
            </thead>
            <tbody>
              <% if (!produtos_criticos || produtos_criticos.length === 0) { %>
                <tr><td colspan="3" class="td-empty">Sem alertas</td></tr>
              <% } %>
              <% (produtos_criticos || []).forEach(p => { %>
                <tr class="row-link" onclick="location.href='/estoque'">
                  <td>
                    <b><%= p.descricao %></b>
                    <div class="muted"><%= (p.cor || '') %> <%= (p.espessura_mm ? (p.espessura_mm + 'mm') : '') %></div>
                  </td>
                  <td><b><%= p.estoque_atual %></b></td>
                  <td><%= p.estoque_minimo %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

  </div>

  <div class="card">
    <div class="card-head">
      <div>
        <div class="h2">Estoque crítico</div>
        <div class="muted">Insumos abaixo do estoque mínimo</div>
      </div>
      <div class="actions">
        <a class="btn btn-ghost" href="/insumos">Ver insumos</a>
      </div>
    </div>

    <div>
      <div class="h3" style="margin:0 0 6px; display:flex; align-items:center; gap:8px;">
        <span class="mini-ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 3h6"/>
            <path d="M10 3v6.2a2 2 0 0 1-.6 1.4L7.6 12.4A2 2 0 0 0 7 13.8V20a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-6.2a2 2 0 0 0-.6-1.4l-1.8-1.8a2 2 0 0 1-.6-1.4V3"/>
            <path d="M7 15h10"/>
          </svg>
        </span>
        Insumos
      </div>
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Insumo</th>
              <th>Atual</th>
              <th>Mín.</th>
            </tr>
          </thead>
          <tbody>
            <% if (!insumos_criticos || insumos_criticos.length === 0) { %>
              <tr><td colspan="3" class="td-empty">Sem alertas</td></tr>
            <% } %>
            <% (insumos_criticos || []).forEach(i => { %>
              <tr class="row-link" onclick="location.href='/insumos'">
                <td>
                  <b><%= i.nome %></b>
                  <div class="muted"><%= i.categoria || '' %> <%= i.unidade ? ('• ' + i.unidade) : '' %></div>
                </td>
                <td><b><%= i.estoque_atual %></b></td>
                <td><%= i.estoque_minimo %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>



<div class="card" style="margin-top:14px;">
  <div class="card-head">
    <div>
      <div class="h2">Bling × Produção</div>
      <div class="muted">Comparativo com base nos pedidos importados do Bling e OPs do sistema.</div>
    </div>
    <div class="card-actions">
      <% if (typeof canModule === 'function' ? canModule('bling') : true) { %>
      <a class="btn btn-outline" href="/bling/pedidos">Abrir Pedidos Bling</a>
    <% } %>
    </div>
  </div>

  <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:10px; margin-top:10px;">
    <div class="kpi">
      <div class="kpi-label">Pedidos Bling importados</div>
      <div class="kpi-value"><%= (bling_stats?.total_importados || 0) %></div>
      <div class="muted" style="font-size:12px;">No período: <b><%= (bling_stats?.no_periodo || 0) %></b></div>
    </div>

    <div class="kpi">
      <div class="kpi-label">Itens (quantidade) no período</div>
      <div class="kpi-value"><%= (bling_stats?.itens_no_periodo || 0) %></div>
      <div class="muted" style="font-size:12px;">Soma das quantidades em <code>pedido_itens</code></div>
    </div>

    <div class="kpi">
      <div class="kpi-label">Pedidos convertidos em OP</div>
      <div class="kpi-value"><%= (bling_stats?.convertidos_em_op || 0) %></div>
      <div class="muted" style="font-size:12px;">Pedidos com <code>op_id</code> preenchido</div>
    </div>
  </div>

  <div style="margin-top:12px;">
    <div class="h3">Situação dos pedidos (importados)</div>
    <div class="table-wrap" style="margin-top:8px;">
      <table class="tbl">
        <thead>
          <tr><th>Situação</th><th style="width:120px; text-align:right;">Quantidade</th></tr>
        </thead>
        <tbody>
          <% (bling_stats?.por_situacao || []).forEach(r => { %>
            <tr>
              <td><%= r.situacao %></td>
              <td style="text-align:right;"><%= r.n %></td>
            </tr>
          <% }) %>
          <% if (!(bling_stats?.por_situacao || []).length) { %>
            <tr><td colspan="2" class="muted" style="padding:12px;">Sem dados do Bling ainda. Importe alguns pedidos para aparecer aqui.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="muted" style="margin-top:10px; font-size:12px;">
    Sync automática do Bling roda a cada <b>10 minutos</b> (últimos 7 dias). Você também pode forçar em <b>Pedidos Bling</b>.
  </div>
</div>

<div class="grid" style="grid-template-columns: 1fr 1fr; gap:14px; margin-top:14px; align-items:start;">
  <div class="card">
    <div class="card-head">
      <div>
        <div class="h2">Consumo de material</div>
        <div class="muted">Produtos mais utilizados nas OPs (últimos <%= dias %> dias)</div>
      </div>
      <div class="actions">
        <a class="btn btn-ghost" href="/relatorio-mensal">Relatório</a>
      </div>
    </div>

    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Produto</th>
            <th>Qtd total</th>
            <th>OPs</th>
          </tr>
        </thead>
        <tbody>
          <% if (!consumo_produtos || consumo_produtos.length === 0) { %>
            <tr><td colspan="3" class="td-empty">Sem consumo no período</td></tr>
          <% } %>

          <% (consumo_produtos || []).slice(0, 12).forEach(r => { %>
            <tr>
              <td>
                <b><%= r.descricao %></b>
                <div class="muted"><%= r.codigo_interno || '' %> <%= (r.cor ? ('• ' + r.cor) : '') %> <%= (r.espessura_mm ? ('• ' + r.espessura_mm + 'mm') : '') %></div>
              </td>
              <td><b><%= r.qtd_total %></b></td>
              <td><%= r.ops %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card-head">
      <div>
        <div class="h2">Consumo de insumos</div>
        <div class="muted">Saídas registradas (últimos <%= dias %> dias)</div>
      </div>
      <div class="actions">
        <a class="btn btn-ghost" href="/insumos">Abrir Insumos</a>
      </div>
    </div>

    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Insumo</th>
            <th>Qtd</th>
            <th>Eventos</th>
          </tr>
        </thead>
        <tbody>
          <% if (!top_insumos || top_insumos.length === 0) { %>
            <tr><td colspan="3" class="td-empty">Sem consumo de insumos no período</td></tr>
          <% } %>
          <% (top_insumos || []).forEach(r => { %>
            <tr>
              <td>
                <b><%= r.nome %></b>
                <div class="muted"><%= r.unidade || 'un' %></div>
              </td>
              <td><b><%= r.qtd_total %></b></td>
              <td><%= r.eventos %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="grid" style="grid-template-columns: 1fr 1fr; gap:14px; margin-top:14px; align-items:start;">
  <div class="card">
    <div class="card-head">
      <div>
        <div class="h2">Movimentações recentes</div>
        <div class="muted">Produtos (estoque)</div>
      </div>
      <div class="actions">
        <a class="btn btn-ghost" href="/estoque">Abrir Estoque</a>
      </div>
    </div>

    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Data</th>
            <th>Produto</th>
            <th>Tipo</th>
            <th>Qtd</th>
          </tr>
        </thead>
        <tbody>
          <% if (!ult_mov_produtos || ult_mov_produtos.length === 0) { %>
            <tr><td colspan="4" class="td-empty">Sem movimentações</td></tr>
          <% } %>
          <% (ult_mov_produtos || []).forEach(mv => { %>
            <tr>
              <td><%= mv.data || '-' %></td>
              <td><%= mv.descricao || mv.codigo_interno || '-' %></td>
              <td><span class="badge"><%= (mv.tipo || '').toUpperCase() %></span></td>
              <td><b><%= mv.quantidade %></b></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card-head">
      <div>
        <div class="h2">Movimentações recentes</div>
        <div class="muted">Insumos</div>
      </div>
      <div class="actions">
        <a class="btn btn-ghost" href="/insumos">Abrir Insumos</a>
      </div>
    </div>

    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Data</th>
            <th>Insumo</th>
            <th>Tipo</th>
            <th>Qtd</th>
          </tr>
        </thead>
        <tbody>
          <% if (!ult_mov_insumos || ult_mov_insumos.length === 0) { %>
            <tr><td colspan="4" class="td-empty">Sem movimentações</td></tr>
          <% } %>
          <% (ult_mov_insumos || []).forEach(mv => { %>
            <tr>
              <td><%= mv.data || '-' %></td>
              <td><%= mv.nome || '-' %></td>
              <td><span class="badge"><%= (mv.tipo || '').toUpperCase() %></span></td>
              <td><b><%= mv.quantidade %></b> <span class="muted"><%= mv.unidade || '' %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  // linha clicável na tabela
  document.querySelectorAll(".row-link").forEach(tr => {
    tr.style.cursor = "pointer";
  });
</script>
