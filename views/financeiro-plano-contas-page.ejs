<%
  const itens = Array.isArray(planoList) ? planoList : [];
%>
<div class="card">
  <div class="card-head">
    <div>
      <div class="h1">Plano de Contas</div>
      <div class="muted">Categorias de receita e despesa (base para DRE, relatórios e dashboard).</div>
    </div>
    <div class="card-actions">
      <a class="btn btn-secondary" href="/financeiro">Voltar</a>
    </div>
  </div>

  <form method="post" action="/financeiro/plano-contas" style="margin-top:12px; display:flex; gap:10px; flex-wrap:wrap;">
    <div style="min-width:140px;">
      <label class="lbl">Código</label>
      <input class="inp" name="codigo" placeholder="Ex: 3.01">
    </div>
    <div style="min-width:280px; flex:1;">
      <label class="lbl">Nome</label>
      <input class="inp" name="nome" required placeholder="Ex: Receita de Vendas">
    </div>
    <div style="min-width:200px;">
      <label class="lbl">Tipo</label>
      <select class="inp" name="tipo">
        <option value="RECEITA">RECEITA</option>
        <option value="DESPESA">DESPESA</option>
      </select>
    </div>
    <div style="align-self:end;">
      <button class="btn btn-primary" type="submit">+ Criar</button>
    </div>
  </form>

  <div class="table-wrap" style="margin-top:12px;">
    <table class="table">
      <thead>
        <tr>
          <th style="width:90px;">#</th>
          <th style="width:120px;">Código</th>
          <th>Nome</th>
          <th style="width:140px;">Tipo</th>
          <th style="width:120px;">Ativo</th>
        </tr>
      </thead>
      <tbody>
        <% if (!itens.length) { %>
          <tr><td colspan="5" class="muted">Nenhum item no plano de contas.</td></tr>
        <% } %>
        <% itens.forEach(p => { %>
          <tr>
            <td><%= p.id %></td>
            <td><%= (p.codigo || '-') %></td>
            <td><b><%= p.nome %></b></td>
            <td><%= p.tipo %></td>
            <td><%= (p.ativo ? 'Sim' : 'Não') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
