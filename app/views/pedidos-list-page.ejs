<% 
  const pedidosArr = Array.isArray(pedidos) ? pedidos : [];
  const f = filtros || {};
  function chipClass(st){
    st = String(st||"").toUpperCase();
    if (st === "CONVERTIDO") return "chip chip-ok";
    if (st === "CANCELADO") return "chip chip-danger";
    if (st === "EM_ANALISE") return "chip chip-info";
    return "chip chip-warn";
  }
%>

<div class="card">
  <div class="card-head">
    <div>
      <div class="h1">Pedidos</div>
      <div class="muted">Pedidos do vendedor (pré-OP). Converta em OP quando estiver pronto.</div>
    </div>
    <div class="card-actions">
      <a class="btn btn-primary" href="/pedidos/novo">+ Novo Pedido</a>
    </div>
  </div>

  <form class="filters" method="get" action="/pedidos" style="margin-top:10px;">
    <div class="row" style="display:flex; gap:10px; flex-wrap:wrap;">
      <div style="flex:1; min-width:220px;">
        <label class="lbl">Busca</label>
        <input class="inp" name="q" placeholder="cliente, contato, vendedor, id..." value="<%= (f.q||'') %>">
      </div>
      <div style="min-width:180px;">
        <label class="lbl">Status</label>
        <select class="inp" name="status">
          <option value="">Todos</option>
          <option value="ABERTO" <%= (f.status==='ABERTO'?'selected':'') %>>ABERTO</option>
          <option value="EM_ANALISE" <%= (f.status==='EM_ANALISE'?'selected':'') %>>EM_ANALISE</option>
          <option value="CONVERTIDO" <%= (f.status==='CONVERTIDO'?'selected':'') %>>CONVERTIDO</option>
          <option value="CANCELADO" <%= (f.status==='CANCELADO'?'selected':'') %>>CANCELADO</option>
        </select>
      </div>
      <div style="min-width:220px;">
        <label class="lbl">Vendedor</label>
        <input class="inp" name="vendedor" placeholder="nome do vendedor" value="<%= (f.vendedor||'') %>">
      </div>
      <div style="min-width:160px;">
        <label class="lbl">De</label>
        <input class="inp" type="date" name="de" value="<%= (f.de||'') %>">
      </div>
      <div style="min-width:160px;">
        <label class="lbl">Até</label>
        <input class="inp" type="date" name="ate" value="<%= (f.ate||'') %>">
      </div>
      <div style="align-self:end;">
        <button class="btn" type="submit">Filtrar</button>
        <a class="btn btn-ghost" href="/pedidos">Limpar</a>
      </div>
    </div>
  </form>

  <div class="table-wrap" style="margin-top:12px;">
    <table class="table">
      <thead>
        <tr>
          <th style="width:90px;">#</th>
          <th>Cliente</th>
          <th>Vendedor</th>
          <th>Prazo</th>
          <th>Prioridade</th>
          <th>Status</th>
          <th style="width:220px;">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (pedidosArr.length === 0) { %>
          <tr><td colspan="7" class="muted">Nenhum pedido encontrado.</td></tr>
        <% } %>

        <% pedidosArr.forEach(p => { %>
          <tr>
            <td><%= p.id %></td>
            <td>
              <div style="font-weight:700;"><%= p.cliente_nome || '-' %></div>
              <div class="muted"><%= p.cliente_contato || '' %></div>
            </td>
            <td><%= p.vendedor_nome || '-' %></td>
            <td><%= p.prazo_entrega || '-' %></td>
            <td><%= p.prioridade || 'NORMAL' %></td>
            <td><span class="<%= chipClass(p.status) %>"><%= (p.status || 'ABERTO') %></span></td>
            <td style="display:flex; gap:8px; flex-wrap:wrap;">
              <a class="btn btn-small" href="/pedidos/<%= p.id %>">Ver</a>
              <% if ((p.status === 'ABERTO' || p.status === 'EM_ANALISE') && !p.op_id) { %>
                <form method="post" action="/pedidos/<%= p.id %>/gerar-op" style="display:inline;">
                  <button class="btn btn-small btn-primary" type="submit">Gerar OP</button>
                </form>
              <% } %>
              <% if (p.op_id) { %>
                <a class="btn btn-small" href="/ops/<%= p.op_id %>">Abrir OP</a>
              <% } %>
              <a class="btn btn-small btn-ghost" href="/pedidos/<%= p.id %>/editar">Editar</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
