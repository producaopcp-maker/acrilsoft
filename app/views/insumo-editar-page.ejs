
<div class="card">
  <div class="h1">Editar insumo</div>
  <div class="muted">O estoque atual é alterado pelas movimentações.</div>

  <form class="form" method="post" action="/insumos/<%= insumo.id %>">
    <div class="grid">
      <label>Nome<input name="nome" value="<%= insumo.nome %>" required /></label>
      <label>Categoria<input name="categoria" value="<%= insumo.categoria || '' %>" /></label>
      <label>Unidade<input name="unidade" value="<%= insumo.unidade || '' %>" /></label>
      <label>Estoque mínimo<input name="estoque_minimo" type="number" value="<%= insumo.estoque_minimo || 0 %>" /></label>
    </div>
    <div style="display:flex; gap:10px; margin-top:12px;">
      <button class="btn" type="submit">Salvar</button>
      <a class="btn btn-ghost" href="/insumos">Voltar</a>
    </div>
  </form>
</div>
